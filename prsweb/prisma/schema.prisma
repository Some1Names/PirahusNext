
generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model AdmissionYear {
  id          String @id @default(cuid())
  mentorYear  String
  menteeYear  String
}

model Mentor {
  id         String @id @default(cuid())
  studentId  String @unique
  password   String?
  name       String?
  isAdmin    Boolean @default(false)
  point      Int     @default(0)
  hints      Hint[]

  mentee     Mentee?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Mentee {
  id         String @id @default(cuid())
  studentId  String @unique
  password   String?
  name       String?
  point               Int     @default(0)
  unlockedHintLevels  Int[]   @default([])

  mentorId   String @unique
  mentor     Mentor @relation(fields: [mentorId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Hint {
  id         String   @id @default(cuid())
  content    String
  level      Int

  mentorId   String
  mentor     Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([mentorId, level])
}