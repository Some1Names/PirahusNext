
generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model AdmissionYear {
  id          String @id @default(cuid())
  mentorYear  String
  menteeYear  String
}

model Mentor {
  id         String @id @default(cuid())
  studentId  String @unique
  password   String?
  nickname   String?
  isAdmin    Boolean @default(false)
  point      Int     @default(0)
  unlockedCosmetics String[] @default([])
  equippedEffect    String?
  hints      Hint[]

  mentee     Mentee?
  minigameRecords MinigameRecord[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Mentee {
  id         String @id @default(cuid())
  studentId  String @unique
  password   String?
  nickname   String?
  point               Int     @default(0)
  unlockedHintLevels  Int[]   @default([])
  unlockedCosmetics   String[] @default([])
  equippedEffect      String?

  mentorId   String @unique
  mentor     Mentor @relation(fields: [mentorId], references: [id])
  minigameRecords MinigameRecord[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Hint {
  id         String   @id @default(cuid())
  content    String
  level      Int

  mentorId   String
  mentor     Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([mentorId, level])
}

model ShopItem {
  id          String   @id @default(cuid())
  category    String
  name        String
  description String
  price       Int
  icon        String
  disabled    Boolean  @default(false)
  effectKey   String?
  hintLevel   Int?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MinigameRecord {
  id        String   @id @default(cuid())
  gameName  String
  timeTaken      Int
  score          Float?
  correctAnswers Int?
  totalAnswers   Int?
  
  menteeId  String?
  mentee    Mentee?  @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  
  mentorId  String?
  mentor    Mentor?  @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([gameName, menteeId])
  @@unique([gameName, mentorId])
}